function FieldGroupEngine({ spec }: { spec: FieldGroupSpec }) {
  const form = useFormContext()

  const [localRows, setLocalRows] = useState([])

  // run fetch effects
  useEffect(() => {
    runEffects(spec.effects, {
      form,
      localRows,
      setLocalRows,
    })
  }, [spec])

  const handleEvent = (event: FormEvent) => {
    runMutation(event, spec, {
      form,
      localRows,
      setLocalRows,
    })
  }

  return (
    <Stack>
      {spec.title && <Text>{spec.title}</Text>}

      {spec.fields.map(field => (
        <FieldRenderer
          key={field.name}
          field={field}
          value={form.get(field.name)}
          onChange={(v) =>
            handleEvent({
              type: 'field-change',
              field: field.name,
              value: v,
            })
          }
        />
      ))}

      {spec.mutationMode !== 'cell' && (
        <MutationControls
          spec={spec}
          onEvent={handleEvent}
          localRows={localRows}
        />
      )}
    </Stack>
  )
}

