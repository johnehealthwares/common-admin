Effect runner:
function runEffects(effects, ctx) {
  effects.forEach(effect => {
    switch (effect.type) {
      case 'fetch':
        return runFetch(effect, ctx)

      case 'sync-form':
        return runSync(effect, ctx)

      case 'compute':
        return runCompute(effect, ctx)
    }
  })
}

